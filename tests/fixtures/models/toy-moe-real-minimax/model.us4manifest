# Sibling manifest for toy-moe-real-minimax.safetensors (issue #81.7b: MoE
# real for minimax). moe_expert_shards points at genuine per-expert
# safetensors files whose real lm_head.weight the runtime applies when the
# router selects that expert (see TryLoadExpertShardLmHead /
# MiniMaxMoEAdapter::Generate).
family=minimax
model_name=toy-moe-real-minimax
weight_dtype=fp32
seed=11
vocabulary=alpha,beta,gamma,delta
default_prompt_token=alpha
moe_expert_shards=expert0.safetensors,expert1.safetensors
