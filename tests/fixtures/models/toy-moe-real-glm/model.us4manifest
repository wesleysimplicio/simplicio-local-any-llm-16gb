# Sibling manifest for toy-moe-real-glm.safetensors (issue #81.7b: MoE real
# for glm). moe_expert_shards points at genuine per-expert safetensors files
# whose real lm_head.weight the runtime applies when the router selects that
# expert (see TryLoadExpertShardLmHead / GlmMoEAdapter::Generate).
family=glm
model_name=toy-moe-real-glm
weight_dtype=fp32
seed=11
vocabulary=alpha,beta,gamma,delta
default_prompt_token=alpha
moe_expert_shards=expert0.safetensors,expert1.safetensors,expert2.safetensors
